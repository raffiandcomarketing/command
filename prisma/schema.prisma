// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  EXECUTIVE
  MANAGER
  MEMBER
  VIEWER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

enum WorkflowTriggerType {
  MANUAL
  SCHEDULED
  EVENT
  WEBHOOK
  CONDITION
}

enum WorkflowInstanceStatus {
  ACTIVE
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

enum WorkflowStepType {
  TASK
  APPROVAL
  NOTIFICATION
  WEBHOOK
  CONDITION
  DELAY
  INTEGRATION
}

enum WorkflowStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  SKIPPED
}

enum AutomationTriggerType {
  SCHEDULE
  EVENT
  CONDITION
  WEBHOOK
  MANUAL
}

enum AutomationExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ApprovalType {
  GENERAL
  PURCHASE
  EXPENSE
  LEAVE
  WORKFLOW
  DOCUMENT
  ACCESS
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  CANCELLED
}

enum KpiDirection {
  HIGHER_IS_BETTER
  LOWER_IS_BETTER
}

enum DocumentType {
  SOP
  POLICY
  GUIDE
  TEMPLATE
  CHECKLIST
  REPORT
}

enum DocumentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  INFO
  WARNING
  ALERT
  TASK
  APPROVAL
  WORKFLOW
  SYSTEM
  ESCALATION
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  KPI_THRESHOLD
  SYSTEM
  DEADLINE
  ESCALATION
  INTEGRATION
}

enum IntegrationType {
  ERP
  POS
  ECOMMERCE
  EMAIL
  SMS
  CALENDAR
  HR
  FINANCE
  SHIPPING
  ANALYTICS
  CUSTOM
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRY
}

enum RecurringScheduleType {
  TASK
  WORKFLOW
  AUTOMATION
  REPORT
}

// ==================== CORE IDENTITY MODELS ====================

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  name                  String
  passwordHash          String
  avatar                String?
  role                  UserRole               @default(MEMBER)
  isActive              Boolean                @default(true)
  lastLoginAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  userDepartments       UserDepartment[]
  tasks                 Task[]                 @relation("assignee")
  createdTasks          Task[]                 @relation("creator")
  teams                 Team[]                 @relation("teamLead")
  approvals             Approval[]             @relation("requester")
  approvalsApproved     Approval[]             @relation("approver")
  approvalSteps         ApprovalStep[]
  documents             Document[]             @relation("author")
  notifications         Notification[]
  alerts                Alert[]                @relation("resolvedBy")
  auditLogs             AuditLog[]
  activityLogs          ActivityLog[]
  automationRules       AutomationRule[]       @relation("createdBy")
  workflowInstances     WorkflowInstance[]     @relation("triggeredBy")
  recurringSchedules    RecurringSchedule[]    @relation("createdBy")
  comments              Comment[]

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Department {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String                 @unique
  description           String?
  icon                  String?
  color                 String?
  sortOrder             Int                    @default(0)
  isActive              Boolean                @default(true)
  parentId              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Self-referencing for sub-departments
  parent                Department?            @relation("SubDepartments", fields: [parentId], references: [id], onDelete: SetNull)
  subDepartments        Department[]           @relation("SubDepartments")

  // Relations
  roles                 Role[]
  teams                 Team[]
  userDepartments       UserDepartment[]
  tasks                 Task[]
  kpiDefinitions        KpiDefinition[]
  documents             Document[]
  integrations          Integration[]
  automationRules       AutomationRule[]
  alerts                Alert[]
  activityLogs          ActivityLog[]
  workflows             Workflow[]
  approvals             Approval[]
  recurringSchedules    RecurringSchedule[]
  comments              Comment[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@map("departments")
}

model Role {
  id                    String                 @id @default(uuid())
  title                 String
  slug                  String
  description           String?
  departmentId          String
  sortOrder             Int                    @default(0)
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  department            Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userDepartments       UserDepartment[]
  rolePermissions       RolePermission[]
  tasks                 Task[]
  kpiDefinitions        KpiDefinition[]
  documents             Document[]

  @@unique([departmentId, slug])
  @@index([departmentId])
  @@index([slug])
  @@index([isActive])
  @@map("roles")
}

model Team {
  id                    String                 @id @default(uuid())
  name                  String
  departmentId          String
  leadUserId            String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  department            Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  leadUser              User                   @relation("teamLead", fields: [leadUserId], references: [id], onDelete: Restrict)

  @@index([departmentId])
  @@index([leadUserId])
  @@map("teams")
}

model UserDepartment {
  userId                String
  departmentId          String
  roleId                String
  isPrimary             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  department            Department             @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  role                  Role                   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
  @@index([roleId])
  @@map("user_departments")
}

model Permission {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String                 @unique
  description           String?
  module                String
  createdAt             DateTime               @default(now())

  // Relations
  rolePermissions       RolePermission[]

  @@index([slug])
  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId                String
  permissionId          String
  createdAt             DateTime               @default(now())

  // Relations - Note: roleId references system roles, not department roles
  role                  Role                   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission            Permission             @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// ==================== TASK & WORKFLOW ENGINE ====================

model Task {
  id                    String                 @id @default(uuid())
  title                 String
  description           String?
  status                TaskStatus             @default(PENDING)
  priority              TaskPriority           @default(MEDIUM)
  dueDate               DateTime?
  assigneeId            String?
  creatorId             String
  departmentId          String?
  roleId                String?
  parentTaskId          String?
  workflowInstanceId    String?
  isRecurring           Boolean                @default(false)
  recurringSchedule     Json?
  tags                  String[]               @default([])
  completedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  assignee              User?                  @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator               User                   @relation("creator", fields: [creatorId], references: [id], onDelete: Restrict)
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  role                  Role?                  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  parentTask            Task?                  @relation("SubTasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subTasks              Task[]                 @relation("SubTasks")
  workflowInstance      WorkflowInstance?      @relation(fields: [workflowInstanceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([departmentId])
  @@index([roleId])
  @@index([parentTaskId])
  @@index([workflowInstanceId])
  @@index([dueDate])
  @@map("tasks")
}

model Workflow {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String
  description           String?
  departmentId          String?
  triggerType           WorkflowTriggerType
  triggerConfig         Json
  steps                 Json
  isActive              Boolean                @default(true)
  isTemplate            Boolean                @default(false)
  version               Int                    @default(1)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  workflowInstances     WorkflowInstance[]

  @@unique([slug, version])
  @@index([slug])
  @@index([departmentId])
  @@index([isActive])
  @@index([isTemplate])
  @@map("workflows")
}

model WorkflowInstance {
  id                    String                 @id @default(uuid())
  workflowId            String
  status                WorkflowInstanceStatus @default(ACTIVE)
  currentStepIndex      Int                    @default(0)
  context               Json?
  startedAt             DateTime               @default(now())
  completedAt           DateTime?
  triggeredById         String?
  error                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  workflow              Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  triggeredBy           User?                  @relation("triggeredBy", fields: [triggeredById], references: [id], onDelete: SetNull)
  workflowSteps         WorkflowStep[]
  tasks                 Task[]

  @@index([workflowId])
  @@index([status])
  @@index([triggeredById])
  @@index([startedAt])
  @@map("workflow_instances")
}

model WorkflowStep {
  id                    String                 @id @default(uuid())
  workflowInstanceId    String
  stepIndex             Int
  name                  String
  type                  WorkflowStepType
  config                Json
  status                WorkflowStepStatus     @default(PENDING)
  result                Json?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  workflowInstance      WorkflowInstance       @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)

  @@unique([workflowInstanceId, stepIndex])
  @@index([workflowInstanceId])
  @@index([status])
  @@map("workflow_steps")
}

// ==================== AUTOMATION ENGINE ====================

model AutomationRule {
  id                    String                 @id @default(uuid())
  name                  String
  description           String?
  departmentId          String?
  isActive              Boolean                @default(true)
  triggerType           AutomationTriggerType
  triggerConfig         Json
  conditions            Json?
  actions               Json[]
  cooldownMinutes       Int?
  lastTriggeredAt       DateTime?
  executionCount        Int                    @default(0)
  createdById           String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy             User                   @relation("createdBy", fields: [createdById], references: [id], onDelete: Restrict)
  automationExecutions  AutomationExecution[]

  @@index([departmentId])
  @@index([isActive])
  @@index([triggerType])
  @@index([createdById])
  @@map("automation_rules")
}

model AutomationExecution {
  id                    String                 @id @default(uuid())
  ruleId                String
  status                AutomationExecutionStatus @default(PENDING)
  triggerData           Json?
  result                Json?
  error                 String?
  startedAt             DateTime               @default(now())
  completedAt           DateTime?
  duration              Int?
  createdAt             DateTime               @default(now())

  // Relations
  rule                  AutomationRule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([status])
  @@index([startedAt])
  @@map("automation_executions")
}

// ==================== APPROVAL SYSTEM ====================

model Approval {
  id                    String                 @id @default(uuid())
  title                 String
  description           String?
  type                  ApprovalType
  status                ApprovalStatus         @default(PENDING)
  requesterId           String
  approverId            String?
  departmentId          String?
  data                  Json?
  priority              TaskPriority           @default(MEDIUM)
  dueDate               DateTime?
  decidedAt             DateTime?
  comments              String?
  escalatedAt           DateTime?
  escalationLevel       Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  requester             User                   @relation("requester", fields: [requesterId], references: [id], onDelete: Restrict)
  approver              User?                  @relation("approver", fields: [approverId], references: [id], onDelete: SetNull)
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  approvalSteps         ApprovalStep[]

  @@index([status])
  @@index([requesterId])
  @@index([approverId])
  @@index([departmentId])
  @@index([type])
  @@index([dueDate])
  @@map("approvals")
}

model ApprovalStep {
  id                    String                 @id @default(uuid())
  approvalId            String
  stepOrder             Int
  approverId            String
  status                ApprovalStatus         @default(PENDING)
  decidedAt             DateTime?
  comments              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  approval              Approval               @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  approver              User                   @relation(fields: [approverId], references: [id], onDelete: Restrict)

  @@unique([approvalId, stepOrder])
  @@index([approvalId])
  @@index([approverId])
  @@index([status])
  @@map("approval_steps")
}

// ==================== KPI & REPORTING ====================

model KpiDefinition {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String
  description           String?
  departmentId          String?
  roleId                String?
  unit                  String
  targetValue           Float
  warningThreshold      Float
  criticalThreshold     Float
  direction             KpiDirection
  dataSource            String
  query                 String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  role                  Role?                  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  snapshots             KpiSnapshot[]

  @@unique([slug])
  @@index([slug])
  @@index([departmentId])
  @@index([roleId])
  @@index([isActive])
  @@map("kpi_definitions")
}

model KpiSnapshot {
  id                    String                 @id @default(uuid())
  kpiId                 String
  value                 Float
  period                String
  recordedAt            DateTime               @default(now())
  metadata              Json?
  createdAt             DateTime               @default(now())

  // Relations
  kpi                   KpiDefinition          @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([kpiId])
  @@index([period])
  @@index([recordedAt])
  @@map("kpi_snapshots")
}

// ==================== SOP & DOCUMENTS ====================

model Document {
  id                    String                 @id @default(uuid())
  title                 String
  slug                  String
  content               String
  type                  DocumentType
  departmentId          String?
  roleId                String?
  version               Int                    @default(1)
  status                DocumentStatus         @default(DRAFT)
  authorId              String
  tags                  String[]               @default([])
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  publishedAt           DateTime?

  // Relations
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  role                  Role?                  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  author                User                   @relation("author", fields: [authorId], references: [id], onDelete: Restrict)

  @@unique([slug, version])
  @@index([slug])
  @@index([type])
  @@index([status])
  @@index([departmentId])
  @@index([authorId])
  @@map("documents")
}

// ==================== NOTIFICATIONS & ALERTS ====================

model Notification {
  id                    String                 @id @default(uuid())
  userId                String
  type                  NotificationType
  title                 String
  message               String
  link                  String?
  isRead                Boolean                @default(false)
  metadata              Json?
  createdAt             DateTime               @default(now())
  readAt                DateTime?

  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model Alert {
  id                    String                 @id @default(uuid())
  title                 String
  message               String
  severity              AlertSeverity
  type                  AlertType
  departmentId          String?
  isResolved            Boolean                @default(false)
  resolvedById          String?
  metadata              Json?
  createdAt             DateTime               @default(now())
  resolvedAt            DateTime?

  // Relations
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  resolvedBy            User?                  @relation("resolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([severity])
  @@index([type])
  @@index([isResolved])
  @@index([departmentId])
  @@index([createdAt])
  @@map("alerts")
}

// ==================== INTEGRATION & WEBHOOKS ====================

model Integration {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String
  type                  IntegrationType
  provider              String
  config                Json
  isActive              Boolean                @default(true)
  lastSyncAt            DateTime?
  departmentId          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  webhooks              Webhook[]

  @@unique([slug])
  @@index([slug])
  @@index([type])
  @@index([isActive])
  @@map("integrations")
}

model Webhook {
  id                    String                 @id @default(uuid())
  name                  String
  url                   String
  secret                String
  events                String[]
  isActive              Boolean                @default(true)
  integrationId         String?
  lastTriggeredAt       DateTime?
  failureCount          Int                    @default(0)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  integration           Integration?           @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  logs                  WebhookLog[]

  @@index([integrationId])
  @@index([isActive])
  @@map("webhooks")
}

model WebhookLog {
  id                    String                 @id @default(uuid())
  webhookId             String
  event                 String
  payload               Json
  response              Json?
  statusCode            Int?
  success               Boolean
  createdAt             DateTime               @default(now())

  // Relations
  webhook               Webhook                @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([event])
  @@index([success])
  @@map("webhook_logs")
}

// ==================== AUDIT & ACTIVITY ====================

model AuditLog {
  id                    String                 @id @default(uuid())
  userId                String?
  action                String
  entity                String
  entityId              String
  changes               Json?
  ipAddress             String?
  userAgent             String?
  metadata              Json?
  createdAt             DateTime               @default(now())

  // Relations
  user                  User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id                    String                 @id @default(uuid())
  userId                String
  type                  String
  description           String
  entityType            String?
  entityId              String?
  departmentId          String?
  metadata              Json?
  createdAt             DateTime               @default(now())

  // Relations
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([type])
  @@index([entityType])
  @@index([departmentId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ==================== JOB QUEUE ====================

model JobQueue {
  id                    String                 @id @default(uuid())
  type                  String
  payload               Json
  status                JobStatus              @default(PENDING)
  priority              Int                    @default(0)
  attempts              Int                    @default(0)
  maxAttempts           Int                    @default(3)
  scheduledFor          DateTime
  startedAt             DateTime?
  completedAt           DateTime?
  error                 String?
  result                Json?
  createdAt             DateTime               @default(now())

  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([scheduledFor])
  @@index([createdAt])
  @@map("job_queue")
}

// ==================== COMMENTS/NOTES ====================

model Comment {
  id                    String                 @id @default(uuid())
  content               String
  authorId              String
  entityType            String
  entityId              String
  parentId              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  author                User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentComment         Comment?               @relation("CommentThreads", fields: [parentId], references: [id], onDelete: Cascade)
  replies               Comment[]              @relation("CommentThreads")

  @@index([authorId])
  @@index([entityType])
  @@index([entityId])
  @@index([parentId])
  @@index([createdAt])
  @@map("comments")
}

// ==================== RECURRING SCHEDULES ====================

model RecurringSchedule {
  id                    String                 @id @default(uuid())
  name                  String
  cronExpression        String
  type                  RecurringScheduleType
  config                Json
  departmentId          String?
  isActive              Boolean                @default(true)
  lastRunAt             DateTime?
  nextRunAt             DateTime?
  createdById           String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  // Relations
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy             User                   @relation("createdBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([type])
  @@index([departmentId])
  @@index([isActive])
  @@index([nextRunAt])
  @@map("recurring_schedules")
}
